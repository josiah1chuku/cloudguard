# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# Data — do not commit raw or processed data to git
data/raw/
data/processed/
data/splits/

# Trained models — large files, use releases or DVC instead
outputs/models/*.pkl
outputs/models/*.pt
outputs/models/*.pth

# Results and figures — regenerate from pipeline
outputs/results/
outputs/figures/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Environment
.env
.env.local
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.pdf
paper/*.synctex.gz
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk

